module Error

(* Error codes *)

type err_t = [
  SUCCESS,
  EMPTY,
  SRC_EMPTY,
  DST_OCCUPIED,
  INVALID_INDEX,
  INVALID_DERIVATION,
  INVALID_MONITOR,
  INVALID_PID,
  INVALID_STATE,
  INVALID_PMP,
  INVALID_SLOT,
  INVALID_SOCKET,
  INVALID_SYSCALL,
  INVALID_REGISTER,
  INVALID_CAPABILITY,
  NO_RECEIVER,
  PREEMPTED,
  TIMEOUT,
  SUSPENDED,
  CONTINUE,
]